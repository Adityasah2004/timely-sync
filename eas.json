{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "SUPABASE_URL": "$SUPABASE_URL",
        "SUPABASE_ANON_KEY": "$SUPABASE_ANON_KEY",
        "EXPO_PUBLIC_GROQ_KEY": "$EXPO_PUBLIC_GROQ_KEY"
      },
      "channel": "preview"
    },
    "production": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "SUPABASE_URL": "$SUPABASE_URL",
        "SUPABASE_ANON_KEY": "$SUPABASE_ANON_KEY",
        "EXPO_PUBLIC_GROQ_KEY": "$EXPO_PUBLIC_GROQ_KEY"
      },
      "channel": "production"
    }
  },
  "submit": {
    "production": {}
  }
}
